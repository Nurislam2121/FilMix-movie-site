<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Избранное</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/base.css" />
    <link rel="stylesheet" href="/css/favourites.css" />
</head>
<body>
    <%- include('partials/header') %>

    <section class="filters-section">
        <form id="movie-filters-form" class="filters-form" action="/favourites" method="GET">
            
            <div class="filters-block filters-block--search">
                <h2 class="filters-block__title">Поиск</h2>
                <div class="search-wrapper">
                    <input
                        type="text"
                        name="search"
                        class="search-input"
                        placeholder="Введите название фильма"
                        value="<%= filters.search || '' %>"
                    />
                    <button type="submit" class="btn btn--primary base-button">Искать</button>
                </div>
            </div>

            <div class="filters-block filters-block--filter">
                <h2 class="filters-block__title">Фильтр</h2>
                <div class="filter-fields">
                    <div class="filter-field">
                        <input type="text" name="genre" class="filter-input" placeholder="Жанр" value="<%= filters.genre || '' %>" />
                    </div>
                    <div class="filter-field">
                        <input type="text" name="year" class="filter-input" placeholder="Год" value="<%= filters.year || '' %>" />
                    </div>
                    <div class="filter-field">
                        <input type="text" name="country" class="filter-input" placeholder="Страна" value="<%= filters.country || '' %>" />
                    </div>
                </div>
            </div>

            <div class="filters-block filters-block--bottom">
                <div class="sort-wrapper">
                    <h2 class="filters-block__title">Сортировка</h2>
                    <div class="custom-select-wrapper">
                        <select name="sort" class="sort-select" id="sort-select" onchange="this.form.submit()">
                            <option value="newest" <%= filters.sort === 'newest' ? 'selected' : '' %>>Сначала новые</option>
                            <option value="rating-desc" <%= filters.sort === 'rating-desc' ? 'selected' : '' %>>Рейтинг ⬇</option>
                            <option value="title-asc" <%= filters.sort === 'title-asc' ? 'selected' : '' %>>Название (А-Я)</option>
                            <option value="year-desc" <%= filters.sort === 'year-desc' ? 'selected' : '' %>>Год ⬇</option>
                        </select>
                        <div class="custom-select-arrow"></div>
                    </div>
                </div>
                <a href="/favourites" class="btn btn--reset base-button" style="text-decoration: none; text-align: center; line-height: 45px;">
                    Сбросить
                </a>
            </div>
        </form>
    </section>

    <% if (favMovies && favMovies.length > 0) { %>
        <section class="all-movies">
            <h2>Ваш список (<%= favMovies.length %>)</h2>
            <div class="all-movies__container film-container">
                <% favMovies.forEach(movie => { %>
                    <article class="all-movies__card film-card">
                        <img src="https://image.tmdb.org/t/p/w500<%= movie.poster_path %>" alt="<%= movie.title %>" />
                        <div class="all-movies__description film-description">
                            <h4 class="all-movies__title-film film-title"><%= movie.title %></h4>
                            <div class="all-movies__date-category year-genre">
                                <p class="all-movies__date film-year"><%= new Date(movie.release_date).getFullYear() %></p>
                                <p class="all-movies__category film-genre"><%= movie.genres %></p>
                            </div>
                            <button class="all-movies__btn base-button film-btn" onclick="location.href='/movie/<%= movie.id %>'">
                                Подробнее
                            </button>
                        </div>
                    </article>
                <% }) %>
            </div>
        </section>
    <% } else { %>
        <section class="empty">
            <div class="empty__container">
                <svg
          width="200"
          height="200"
          viewBox="0 0 500 500"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          xmlns:xlink="http://www.w3.org/1999/xlink"
        >
          <rect width="500" height="500" fill="url(#pattern0_107_26)" />
          <defs>
            <pattern
              id="pattern0_107_26"
              patternContentUnits="objectBoundingBox"
              width="1"
              height="1"
            >
              <use xlink:href="#image0_107_26" transform="scale(0.00390625)" />
            </pattern>
            <image
              id="image0_107_26"
              width="256"
              height="256"
              preserveAspectRatio="none"
              xlink:href="data:image/png;base64,"
            />
          </defs>
        </svg>
                <h3 class="empty__description">
                    <%= (filters.search || filters.genre || filters.year) ? 'По вашему запросу ничего не найдено' : 'В списке избранного пока пусто' %>
                </h3>
                <button class="empty__button base-button">
                    <a href="/movie" style="color: white; text-decoration: none;">В каталог</a>
                </button>
            </div>
        </section>
    <% } %>

    <%- include('partials/footer') %>

    <script type="module" src="/js/module.js"></script>
</body>
</html>