<link rel="stylesheet" href="/css/base.css">
<link rel="stylesheet" href="/css/admin.css">

<main class="admin-container">
    <div class="admin-header">
        <h1 class="admin-title">Панель администратора</h1>
        <a href="/admin/reviews" class="base-button secondary">Модерация рецензий</a>
    </div>

    <div class="stats-grid">
        <div class="stat-card">
            <span class="stat-value"><%= stats.total_movies %></span>
            <span class="stat-label">Фильмов</span>
        </div>
        <div class="stat-card">
            <span class="stat-value"><%= stats.total_users %></span>
            <span class="stat-label">Пользователей</span>
        </div>
        <div class="stat-card">
            <span class="stat-value"><%= stats.total_reviews %></span>
            <span class="stat-label">Рецензий</span>
        </div>
    </div>

    <% if (error && error.length > 0) { %>
        <div class="alert alert-error"><%= error %></div>
    <% } %>
    <% if (success && success.length > 0) { %>
        <div class="alert alert-success"><%= success %></div>
    <% } %>

    <div class="admin-grid">
        <aside>
            <section class="admin-section">
                <h3>Управление подборками</h3>
                <form action="/admin/collection" method="POST">
                    <input type="text" name="name" placeholder="Название подборки" required class="admin-input">
                    <button type="submit" class="base-button full-width">Создать группу</button>
                </form>

                <div class="scroll-list">
                    <% collections.forEach(col => { %>
                        <div class="list-item">
                            <span><%= col.name %></span>
                            <form action="/admin/collection/delete" method="POST">
                                <input type="hidden" name="id" value="<%= col.id %>">
                                <button type="submit" class="btn-icon-delete" onclick="return confirm('Удалить подборку?')">✖</button>
                            </form>
                        </div>
                    <% }) %>
                </div>
            </section>

            <section class="admin-section">
                <h3>Удалить фильм из базы</h3>
                <form action="/admin" method="GET" class="search-mini">
                    <input type="text" name="movieSearch" placeholder="Поиск по названию..." value="<%= movieSearch %>" class="admin-input">
                    <button type="submit" class="base-button">🔍</button>
                </form>
                
                <div class="scroll-list mt-10">
                    <% allMovies.forEach(m => { %>
                        <div class="list-item">
                            <span title="<%= m.title %>"><%= m.title.substring(0, 20) %>...</span>
                            <form action="/admin/movie/delete" method="POST">
                                <input type="hidden" name="id" value="<%= m.id %>">
                                <button type="submit" class="btn-icon-delete" onclick="return confirm('Удалить фильм навсегда?')">🗑</button>
                            </form>
                        </div>
                    <% }) %>
                </div>
            </section>
        </aside>

        <section>
            <div class="admin-section no-bg">
                <h3>Управление пользователями</h3>
                <div class="table-wrapper">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Имя</th>
                                <th>Email</th>
                                <th>Роль</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% users.forEach(u => { %>
                                <tr>
                                    <td><%= u.username %></td>
                                    <td><%= u.email %></td>
                                    <td><span class="badge <%= u.is_admin ? 'admin' : 'user' %>"><%= u.is_admin ? 'Админ' : 'Юзер' %></span></td>
                                    <td>
                                        <div class="actions">
                                            <form action="/admin/user/toggle-admin/<%= u.id %>" method="POST">
                                                <button type="submit" class="btn-small">Права</button>
                                            </form>
                                            <form action="/admin/user/delete/<%= u.id %>" method="POST">
                                                <button type="submit" class="btn-small btn-danger" onclick="return confirm('Удалить пользователя?')">Удалить</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>

            <hr class="separator">

            <div class="admin-section no-bg">
                <h3>Добавить фильм из TMDB</h3>
                <form action="/admin/search" method="GET" class="search-main">
                    <input type="text" name="query" placeholder="Введите название фильма..." required class="admin-input">
                    <button type="submit" class="base-button">Найти в TMDB</button>
                </form>
            </div>

            <div class="movie-results">
    <% if (results) { %>
        <% results.forEach(movie => { %>
            <div class="movie-card">
                <div class="movie-card-poster">
                    <% if (movie.poster_path) { %>
                        <img src="https://image.tmdb.org/t/p/w300<%= movie.poster_path %>" alt="<%= movie.title %>">
                    <% } else { %>
                        <div class="no-photo">Нет фото</div>
                    <% } %>
                </div>
                
                <div class="movie-card-content">
                    <h4 class="movie-card-title"><%= movie.title %></h4>
                    
                    <form action="/admin/add" method="POST" class="add-movie-form">
                        <input type="hidden" name="tmdb_id" value="<%= movie.id %>">
                        
                        <select name="collection_id" class="admin-input-select">
                            <option value="">Без подборки</option>
                            <% collections.forEach(col => { %>
                                <option value="<%= col.id %>"><%= col.name %></option>
                            <% }) %>
                        </select>

                        <div class="popularity-checkbox">
                            <input class="admin-checkbox" type="checkbox" name="is_popular" value="true" id="pop-<%= movie.id %>">
                            <label for="pop-<%= movie.id %>">Популярный</label>
                        </div>

                        <button type="submit" class="base-button add-btn">В базу</button>
                    </form>
                </div>
            </div>
        <% }) %>
    <% } %>
</div>
        </section>

        <script type="module" src="/js/module.js"></script>
    </div>
</main>