<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Регистрация | Filmix</title>

    <link rel="stylesheet" href="/css/base.css" />
    <link rel="stylesheet" href="/css/registration.css" />
  </head>
  <body>
    <main class="registration-container">
      <h1>Регистрация</h1>
      <div class="registration-card">
        
        <% if (error && error.length > 0) { %>
          <div class="alert alert-error">
            <%= error %>
          </div>
        <% } %>

        <form class="registration-form" action="/auth/registration" method="POST">
          <label for="username">Имя пользователя</label>
          <input name="username" class="user-name" type="text" placeholder="Введите имя пользователя" required/>
          
          <label for="email">Почта</label>
          <input name="email" class="user-email" type="email" placeholder="Введите почту" required/>
          
          <label for="password">Пароль</label>
          <input name="password" class="user-password" type="password" placeholder="Введите пароль" required/>
          
          <label for="passwordConfirm">Подтверждение пароля</label>
          <input name="passwordConfirm" class="user-password-confirm" type="password" placeholder="Подтвердите пароль" required/>
          
          <button type="submit" class="registration-button base-button">Продолжить</button>
        </form>
        
        <span>Уже есть аккаунт? <b><a class="login-link" href="/auth/login">Войти</a></b></span>
      </div>
    </main>
  </body>
</html>